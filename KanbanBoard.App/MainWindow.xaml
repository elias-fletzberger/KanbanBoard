<Window x:Class="KanbanBoard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KanbanBoard.App"
        xmlns:models="clr-namespace:KanbanBoard.Core.Models;assembly=KanbanBoard.Core"
        mc:Ignorable="d"
        Title="KanbanBoard" Height="600" Width="1000">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <DataTemplate x:Key="CardTemplate">
            <Border x:Name="ItemBorder"
                    Background="White"
                    BorderBrush="LightGray"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8"
                    Margin="4">
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontWeight="Bold"
                               FontSize="13"
                               TextWrapping="Wrap"                       
                               MaxHeight="40"                       
                               HorizontalAlignment="Center"                      
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Description}"                       
                               TextWrapping="Wrap"                       
                               MaxHeight="40"                       
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding DueDate, StringFormat='Fällig: {0:dd.MM.yyyy}'}"                       
                               FontSize="11"                       
                               Foreground="Gray"/>
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:CardStatus.ToDo}">
                    <Setter TargetName="ItemBorder" Property="Background" Value="LightPink"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:CardStatus.Doing}">
                    <Setter TargetName="ItemBorder" Property="Background" Value="LightSkyBlue"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:CardStatus.Done}">
                    <Setter TargetName="ItemBorder" Property="Background" Value="LightSeaGreen"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="RootGrid"
          Background="{Binding Theme.WindowBackground}"
          AllowDrop="True"
          DragOver="RootGrid_DragOver">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Menu-Bar -->
        <Border Grid.Row="0"
                Background="{Binding Theme.ToolbarBackground}"
                BorderBrush="{Binding Theme.ToolbarBorder}"
                BorderThickness="0,0,0,2">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,5,0,5">

                <Button Width="32" Height="32"
                        BorderThickness="0"
                        Background="Transparent"
                        FocusVisualStyle="{x:Null}"
                        Command="{Binding CreateCardCommand}"
                        ToolTip="add new card"
                        Margin="0,0,20,0">
                    <Viewbox Width="28" Height="28">
                        <Grid Width="16" Height="16">
                            <Grid.Resources>
                                <Style TargetType="Path">
                                    <Setter Property="Fill"
                                            Value="{Binding Theme.TextColor}"/>
                                </Style>
                            </Grid.Resources>
                            <Path Data="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z"/>
                            <Path Data="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/>
                        </Grid>
                    </Viewbox>
                </Button>

                <Button Width="32" Height="32"
                        BorderThickness="0"
                        Background="Transparent"
                        FocusVisualStyle="{x:Null}"
                        Command="{Binding DeleteCardCommand}"
                        ToolTip="delete selected card"
                        Margin="0,0,20,0">
                    <Viewbox Width="28" Height="28">
                        <Grid Width="16" Height="16">
                            <Grid.Resources>
                                <Style TargetType="Path">
                                    <Setter Property="Fill"
                                            Value="{Binding Theme.TextColor}"/>
                                </Style>
                            </Grid.Resources>
                            <Path Data="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5"/>
                        </Grid>
                    </Viewbox>
                </Button>

                <ComboBox Width="100"
                          Height="28"
                          FontSize="14"
                          FontWeight="Bold"
                          BorderThickness="0"
                          ItemsSource="{Binding SortModes}"
                          SelectedItem="{Binding SelectedSortMode}"
                          ToolTip="sort cards">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="Normal"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
                <Button Width="16" Height="28"
                        BorderThickness="0"
                        FocusVisualStyle="{x:Null}"
                        Command="{Binding ChangeSortDirectionCommand}"
                        ToolTip="ascending / descending">
                    <StackPanel>
                        <Image Source="{Binding SortDirectionIcon}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,5,30,5">
            <Button Width="26" Height="26"
                    BorderThickness="0"
                    Background="Transparent"
                    FocusVisualStyle="{x:Null}"
                    Command="{Binding ChangeDarkmodeCommand}"
                    ToolTip="Darkmode / Whitemode">
                <StackPanel>
                    <Image Source="{Binding Theme.DarkmodeIcon}"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Card-Lists: ToDo / Doing / Done -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ToDo -->
            <TextBlock Grid.Column="0" Grid.Row="0"
                       Text="To Do"
                       FontWeight="Bold"
                       FontSize="20"
                       Foreground="{Binding Theme.TextColor}"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Center"
                       Margin="10,10,10,0"/>
            <ListBox Grid.Column="0" Grid.Row="1"
                     Background="{Binding Theme.ColumnBackground}"
                     BorderBrush="{Binding Theme.ColumnBorder}"
                     BorderThickness="2"
                     ItemsSource="{Binding ToDoCards}"
                     SelectedItem="{Binding SelectedCard}"
                     ItemTemplate="{StaticResource CardTemplate}"
                     Margin="10"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     PreviewMouseMove="ListBox_PreviewMouseMove"
                     AllowDrop="True"
                     Drop="ListBox_Drop"
                     MouseDoubleClick="ListBox_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Doing -->
            <TextBlock Grid.Column="1" Grid.Row="0"
                       Text="Doing"
                       FontWeight="Bold"
                       FontSize="20"
                       Foreground="{Binding Theme.TextColor}"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Center"
                       Margin="10,10,10,0"/>
            <ListBox Grid.Column="1" Grid.Row="1"
                     Background="{Binding Theme.ColumnBackground}"
                     BorderBrush="{Binding Theme.ColumnBorder}"
                     BorderThickness="2"
                     ItemsSource="{Binding DoingCards}"
                     SelectedItem="{Binding SelectedCard}"
                     ItemTemplate="{StaticResource CardTemplate}"
                     Margin="10"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     PreviewMouseMove="ListBox_PreviewMouseMove"
                     AllowDrop="True"
                     Drop="ListBox_Drop"
                     MouseDoubleClick="ListBox_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Done -->
            <TextBlock Grid.Column="2" Grid.Row="0"
                       Text="Done"
                       FontWeight="Bold"
                       FontSize="20"
                       Foreground="{Binding Theme.TextColor}"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Center"
                       Margin="10,10,10,0"/>
            <ListBox Grid.Column="2" Grid.Row="1"
                     Background="{Binding Theme.ColumnBackground}"
                     BorderBrush="{Binding Theme.ColumnBorder}"
                     BorderThickness="2"
                     ItemsSource="{Binding DoneCards}"
                     SelectedItem="{Binding SelectedCard}"
                     ItemTemplate="{StaticResource CardTemplate}"
                     Margin="10"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     PreviewMouseMove="ListBox_PreviewMouseMove"
                     AllowDrop="True"
                     Drop="ListBox_Drop"
                     MouseDoubleClick="ListBox_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>
    </Grid>
</Window>