<Window x:Class="KanbanBoard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KanbanBoard.App"
        xmlns:models="clr-namespace:KanbanBoard.Core.Models;assembly=KanbanBoard.Core"
        mc:Ignorable="d"
        Title="KanbanBoard" Height="600" Width="1300">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <DataTemplate x:Key="CardTemplate">
            <Border x:Name="ItemBorder"
                    Background="White"
                    BorderBrush="LightGray"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8"
                    Margin="4">
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontWeight="Bold"
                               FontSize="13"
                               TextWrapping="Wrap"                       
                               MaxHeight="40"                       
                               HorizontalAlignment="Center"                      
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Description}"                       
                               TextWrapping="Wrap"                       
                               MaxHeight="40"                       
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding DueDate, StringFormat='Fällig: {0:dd.MM.yyyy}'}"                       
                               FontSize="11"                       
                               Foreground="Gray"/>
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:CardStatus.ToDo}">
                    <Setter TargetName="ItemBorder" Property="Background" Value="LightPink"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:CardStatus.Doing}">
                    <Setter TargetName="ItemBorder" Property="Background" Value="LightSkyBlue"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:CardStatus.Done}">
                    <Setter TargetName="ItemBorder" Property="Background" Value="LightSeaGreen"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="RootGrid"
          AllowDrop="True"
          DragOver="RootGrid_DragOver">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Menu-Bar -->
        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,5,0,5">
            <Button Width="32" Height="32"
                    BorderThickness="0"
                    Background="Transparent"
                    FocusVisualStyle="{x:Null}"
                    Command="{Binding CreateCardCommand}"
                    ToolTip="add new card"
                    Margin="0,0,20,0">
                <StackPanel>
                    <Image Source="/icons/plus-square.png"/>
                </StackPanel>
            </Button>
            <Button Width="32" Height="32"
                    BorderThickness="0"
                    Background="Transparent"
                    FocusVisualStyle="{x:Null}"
                    Command="{Binding DeleteCardCommand}"
                    ToolTip="delete selected card"
                    Margin="0,0,20,0">
                <StackPanel>
                    <Image Source="/icons/trash3.png"/>
                </StackPanel>
            </Button>
            <TextBlock Text="sort cards:"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>
            <Button Content="created at"
                    Width="60" Height="30"
                    BorderThickness="0"
                    Margin="0,0,5,0"/>
            <Button Content="updated at"
                    Width="65" Height="30"
                    BorderThickness="0"
                    Margin="0,0,5,0"/>
            <Button Content="due date"
                    Width="55" Height="30"
                    BorderThickness="0"
                    Margin="0,0,0,0"/>
            
        </StackPanel>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,5,30,5">
            <Button Width="26" Height="26"
                    BorderThickness="0"
                    Background="Transparent"
                    FocusVisualStyle="{x:Null}"
                    ToolTip="Darkmode"
                    Margin="0">
                <StackPanel>
                    <Image Source="/icons/moon.png"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Card-Lists: ToDo / Doing / Done -->
            <TextBlock Grid.Column="0" Grid.Row="0"
                       Text="To Do"
                       FontWeight="Bold"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       Margin="10"/>
            <ListBox Grid.Column="0" Grid.Row="1"
                     ItemsSource="{Binding ToDoCards}"
                     SelectedItem="{Binding SelectedCard}"
                     ItemTemplate="{StaticResource CardTemplate}"
                     Margin="10"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     PreviewMouseMove="ListBox_PreviewMouseMove"
                     AllowDrop="True"
                     Drop="ListBox_Drop">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <TextBlock Grid.Column="1" Grid.Row="0"
                       Text="Doing"
                       FontWeight="Bold"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       Margin="10"/>
            <ListBox Grid.Column="1" Grid.Row="1"
                     ItemsSource="{Binding DoingCards}"
                     SelectedItem="{Binding SelectedCard}"
                     ItemTemplate="{StaticResource CardTemplate}"
                     Margin="10"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     PreviewMouseMove="ListBox_PreviewMouseMove"
                     AllowDrop="True"
                     Drop="ListBox_Drop">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <TextBlock Grid.Column="2" Grid.Row="0"
                       Text="Done"
                       FontWeight="Bold"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       Margin="10"/>
            <ListBox Grid.Column="2" Grid.Row="1"
                     ItemsSource="{Binding DoneCards}"
                     SelectedItem="{Binding SelectedCard}"
                     ItemTemplate="{StaticResource CardTemplate}"
                     Margin="10"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     PreviewMouseMove="ListBox_PreviewMouseMove"
                     AllowDrop="True"
                     Drop="ListBox_Drop">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>


            <!-- Right Side: Details -->
            <StackPanel Grid.Column="3" Grid.Row="0" Orientation="Horizontal" Margin="10,0,10,0">
                <TextBlock Text="DETAILS"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center" 
                           Margin="10"/>
            </StackPanel>
            <StackPanel Grid.Column="3" Grid.Row="1"  Margin="20,10,20,10">
            <TextBlock Text="Titel" FontWeight="Bold"/>
            <TextBox Text="{Binding SelectedCard.Title, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5,0,15"/>

            <TextBlock Text="Status" FontWeight="Bold"/>
            <ComboBox ItemsSource="{Binding StatusValues}"
                     SelectedItem="{Binding SelectedCard.Status}"
                     Margin="0,5,0,15"/>

            <TextBlock Text="Beschreibung" FontWeight="Bold"/>
            <TextBox Text="{Binding SelectedCard.Description, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     Height="100"
                     TextWrapping="Wrap"
                     Margin="0,5,0,15"/>

            <TextBlock Text="Tags" FontWeight="Bold"/>
            <TextBox Text="{Binding TagsText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5,0,35"/>

            <TextBlock Text="Fällig am" FontWeight="Bold"/>
            <DatePicker SelectedDate="{Binding SelectedCard.DueDate}"
                     Padding="5,0,5,0"
                     Margin="0,5,250,25"/>


            <TextBlock Text="Erstellt am" FontWeight="Bold"/>
            <TextBlock Text="{Binding SelectedCard.CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                     Margin="0,5,250,15"/>

            <TextBlock Text="Zuletzt geändert" FontWeight="Bold"/>
            <TextBlock Text="{Binding SelectedCard.UpdatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                     Margin="0,5,250,0"/>
        </StackPanel>
        </Grid>
    </Grid>
</Window>
