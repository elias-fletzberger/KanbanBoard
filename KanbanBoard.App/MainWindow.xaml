<Window x:Class="KanbanBoard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KanbanBoard.App"
        xmlns:models="clr-namespace:KanbanBoard.Core.Models;assembly=KanbanBoard.Core"
        mc:Ignorable="d"
        Title="KanbanBoard" Height="600" Width="1000">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <DataTemplate x:Key="CardTemplate">
            <Border x:Name="ItemBorder"
                    Background="White"
                    BorderBrush="LightGray"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8"
                    Margin="4">
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontWeight="Bold"
                               FontSize="13"
                               TextWrapping="Wrap"                       
                               MaxHeight="40"                       
                               HorizontalAlignment="Center"                      
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Description}"                       
                               TextWrapping="Wrap"                       
                               MaxHeight="40"                       
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding DueDate, StringFormat='Fällig: {0:dd.MM.yyyy}'}"                       
                               FontSize="11"                       
                               Foreground="Gray"/>
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:CardStatus.ToDo}">
                    <Setter TargetName="ItemBorder" Property="Background" Value="LightPink"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:CardStatus.Doing}">
                    <Setter TargetName="ItemBorder" Property="Background" Value="LightSkyBlue"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:CardStatus.Done}">
                    <Setter TargetName="ItemBorder" Property="Background" Value="LightSeaGreen"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="RootGrid"
          AllowDrop="True"
          DragOver="RootGrid_DragOver">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Menu-Bar -->
        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,5,0,5">
            <Button Width="32" Height="32"
                    BorderThickness="0"
                    Background="Transparent"
                    FocusVisualStyle="{x:Null}"
                    Command="{Binding CreateCardCommand}"
                    ToolTip="add new card"
                    Margin="0,0,20,0">
                <StackPanel>
                    <Image Source="/icons/plus-square.png"/>
                </StackPanel>
            </Button>
            
            <Button Width="32" Height="32"
                    BorderThickness="0"
                    Background="Transparent"
                    FocusVisualStyle="{x:Null}"
                    Command="{Binding DeleteCardCommand}"
                    ToolTip="delete selected card"
                    Margin="0,0,20,0">
                <StackPanel>
                    <Image Source="/icons/trash3.png"/>
                </StackPanel>
            </Button>

            <ComboBox Width="100"
                      Height="28"
                      FontSize="14"
                      FontWeight="Bold"
                      BorderThickness="0"
                      ToolTip="sort cards"
                      SelectedIndex="0">
                <ComboBoxItem Content="created at"
                              FontSize="12"
                              FontWeight="Normal"/>
                <ComboBoxItem Content="updated at"
                              FontSize="12"
                              FontWeight="Normal"/>
                <ComboBoxItem Content="due date"
                              FontSize="12"
                              FontWeight="Normal"/>
            </ComboBox>
            <Button Width="16" Height="28"
                    BorderThickness="0"
                    FocusVisualStyle="{x:Null}"
                    Command="{Binding ChangeSortDirectionCommand}"
                    ToolTip="ascending / descending">
                <StackPanel>
                    <Image Source="{Binding SortDirectionIcon}"/>
                </StackPanel>
            </Button>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,5,30,5">
            <Button Width="26" Height="26"
                    BorderThickness="0"
                    Background="Transparent"
                    FocusVisualStyle="{x:Null}"
                    ToolTip="Darkmode"
                    Margin="0">
                <StackPanel>
                    <Image Source="/icons/moon.png"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Card-Lists: ToDo / Doing / Done -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ToDo -->
            <TextBlock Grid.Column="0" Grid.Row="0"
                       Text="To Do"
                       FontWeight="Bold"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       Margin="10"/>
            <ListBox Grid.Column="0" Grid.Row="1"
                     ItemsSource="{Binding ToDoCards}"
                     SelectedItem="{Binding SelectedCard}"
                     ItemTemplate="{StaticResource CardTemplate}"
                     Margin="10"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     PreviewMouseMove="ListBox_PreviewMouseMove"
                     AllowDrop="True"
                     Drop="ListBox_Drop"
                     MouseDoubleClick="ListBox_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
    
            <!-- Doing -->
            <TextBlock Grid.Column="1" Grid.Row="0"
                       Text="Doing"
                       FontWeight="Bold"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       Margin="10"/>
            <ListBox Grid.Column="1" Grid.Row="1"
                     ItemsSource="{Binding DoingCards}"
                     SelectedItem="{Binding SelectedCard}"
                     ItemTemplate="{StaticResource CardTemplate}"
                     Margin="10"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     PreviewMouseMove="ListBox_PreviewMouseMove"
                     AllowDrop="True"
                     Drop="ListBox_Drop"
                     MouseDoubleClick="ListBox_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
    
            <!-- Done -->
            <TextBlock Grid.Column="2" Grid.Row="0"
                       Text="Done"
                       FontWeight="Bold"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       Margin="10"/>
            <ListBox Grid.Column="2" Grid.Row="1"
                     ItemsSource="{Binding DoneCards}"
                     SelectedItem="{Binding SelectedCard}"
                     ItemTemplate="{StaticResource CardTemplate}"
                     Margin="10"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     PreviewMouseMove="ListBox_PreviewMouseMove"
                     AllowDrop="True"
                     Drop="ListBox_Drop"
                     MouseDoubleClick="ListBox_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>
    </Grid>
</Window>
