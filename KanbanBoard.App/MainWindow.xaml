<Window x:Class="KanbanBoard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KanbanBoard.App"
        xmlns:models="clr-namespace:KanbanBoard.Core.Models;assembly=KanbanBoard.Core"
        mc:Ignorable="d"
        Title="KanbanBoard" Height="600" Width="1300">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- Left Side: Card-Lists ToDo / Doing / Done -->
        <TextBlock Grid.Column="0" Grid.Row="0"
                   Text="To Do"
                   FontWeight="Bold"
                   FontSize="20"
                   HorizontalAlignment="Center"
                   Margin="10"/>
        <ListBox Grid.Column="0" Grid.Row="1"
                 ItemsSource="{Binding ToDoCards}"
                 SelectedItem="{Binding SelectedCard}"
                 Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray"
                            Background="LightPink"
                            BorderThickness="1"
                            CornerRadius="4"
                            Width="243"
                            Padding="8"
                            Margin="4">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Description}"
                                       TextWrapping="Wrap"
                                       MaxHeight="40"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding DueDate, StringFormat='Fällig: {0:dd.MM.yyyy}'}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Column="1" Grid.Row="0"
                   Text="Doing"
                   FontWeight="Bold"
                   FontSize="20"
                   HorizontalAlignment="Center"
                   Margin="10"/>
        <ListBox Grid.Column="1" Grid.Row="1"
                 ItemsSource="{Binding DoingCards}"
                 SelectedItem="{Binding SelectedCard}"
                 Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray"
                    Background="LightSkyBlue"
                    BorderThickness="1"
                    CornerRadius="4"
                    Width="243"
                    Padding="8"
                    Margin="4">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}"
                               FontWeight="Bold"
                               FontSize="13"
                               HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Description}"
                               TextWrapping="Wrap"
                               MaxHeight="40"
                               TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding DueDate, StringFormat='Fällig: {0:dd.MM.yyyy}'}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Column="2" Grid.Row="0"
                   Text="Done"
                   FontWeight="Bold"
                   FontSize="20"
                   HorizontalAlignment="Center"
                   Margin="10"/>
        <ListBox Grid.Column="2" Grid.Row="1"
                 ItemsSource="{Binding DoneCards}"
                 SelectedItem="{Binding SelectedCard}"
                 Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray"
                    Background="LightSeaGreen"
                    BorderThickness="1"
                    CornerRadius="4"
                    Width="243"
                    Padding="8"
                    Margin="4">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}"
                               FontWeight="Bold"
                               FontSize="13"
                               HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Description}"
                               TextWrapping="NoWrap"
                               MaxHeight="40"
                               TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding DueDate, StringFormat='Fällig: {0:dd.MM.yyyy}'}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>


        <!-- Right Side: Details -->
        <StackPanel Grid.Column="3" Grid.Row="0" Orientation="Horizontal" Margin="10,0,10,0">
            <TextBlock Grid.Column="1" Grid.Row="0"
                       Text="DETAILS"
                       FontWeight="Bold"
                       FontSize="16"
                       VerticalAlignment="Center" 
                       Margin="10"/>
            
            <Button Content="Neue Karte"                 
            Command="{Binding CreateCardCommand}" 
            Width="100"
            Height="30"
            Margin="40,10,10,10"/>

            <Button Content="lösche Karte"
            Command="{Binding DeleteCardCommand}"
            Width="100"
            Height="30"
            Margin="10"/>
        </StackPanel>

        <StackPanel Grid.Column="3" Grid.Row="1"  Margin="20,10,20,20">
            <TextBlock Text="Titel" FontWeight="Bold"/>
            <TextBox Text="{Binding SelectedCard.Title, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5,0,15"/>

            <TextBlock Text="Status" FontWeight="Bold"/>
            <ComboBox ItemsSource="{Binding StatusValues}"
                     SelectedItem="{Binding SelectedCard.Status}"
                     Margin="0,5,0,15"/>

            <TextBlock Text="Beschreibung" FontWeight="Bold"/>
            <TextBox Text="{Binding SelectedCard.Description, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     Height="100"
                     TextWrapping="Wrap"
                     Margin="0,5,0,15"/>

            <TextBlock Text="Tags" FontWeight="Bold"/>
            <TextBox Text="{Binding TagsText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5,0,35"/>

            <TextBlock Text="Fällig am" FontWeight="Bold"/>
            <DatePicker SelectedDate="{Binding SelectedCard.DueDate}"
                     Padding="5,0,5,0"
                     Margin="0,5,250,25"/>


            <TextBlock Text="Erstellt am" FontWeight="Bold"/>
            <TextBlock Text="{Binding SelectedCard.CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                     Margin="0,5,250,15"/>

            <TextBlock Text="Zuletzt geändert" FontWeight="Bold"/>
            <TextBlock Text="{Binding SelectedCard.UpdatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                     Margin="0,5,250,0"/>
        </StackPanel>
    </Grid>
</Window>
