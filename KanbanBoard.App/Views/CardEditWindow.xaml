<Window x:Class="KanbanBoard.App.Views.CardEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KanbanBoard.App.Views"
        mc:Ignorable="d"
        Title="Karte bearbeiten" Height="500" Width="400">
    <Window.Resources>
        <Style x:Key="StatusComboBoxStyle"
               TargetType="ComboBox"
               BasedOn="{StaticResource ThemedComboBoxStyle}">
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Tag" Value="100"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="BorderBrush" Value="{Binding Theme.ColumnBorder}"/>
        </Style>

        <Style x:Key="ColoredDatePickerStyle"
               TargetType="DatePicker"
               BasedOn="{StaticResource ThemedDatePickerStyle}">
            
        </Style>
    </Window.Resources>
    
    <Grid Background="{Binding Theme.WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titel Bar -->
        <Border Grid.Row="0"
                Background="{Binding Theme.ToolBarBackground}"
                BorderBrush="{Binding Theme.ToolBarBorder}"
                BorderThickness="0,0,0,3">
            <TextBox Text="{Binding Card.Title, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent"
                     BorderBrush="Transparent"
                     BorderThickness="0"
                     Foreground="{Binding Theme.TextColor}"
                     FontSize="20"
                     FontWeight="Bold"
                     ToolTip="titel"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Center"
                     Margin="15,0,0,0"/>
        </Border>

        <Grid Grid.Row="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="5*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <!-- Description Box -->
            <TextBox Grid.Row="0"
                     Text="{Binding Card.Description, UpdateSourceTrigger=PropertyChanged}"
                     Background="{Binding Theme.ColumnBackground}"
                     BorderBrush="{Binding Theme.ColumnBorder}"
                     BorderThickness="2"
                     Foreground="{Binding Theme.TextColor}"
                     FontSize="13"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     ToolTip="description"
                     Padding="5"
                     Margin="10"/>

            <!-- Tags Box -->
            <TextBox Grid.Row="1"
                     Text="{Binding TagsText, UpdateSourceTrigger=PropertyChanged}"
                     Background="{Binding Theme.ColumnBackground}"
                     BorderBrush="{Binding Theme.ColumnBorder}"
                     BorderThickness="2"
                     Foreground="{Binding Theme.TextColor}"
                     FontSize="13"
                     ToolTip="tags"
                     MaxHeight="35"
                     VerticalContentAlignment="Center"
                     Padding="5,0,0,0"
                     Margin="10"/>

            <!-- Status-Button & Due Date -->
            <Grid Grid.Row="2" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding StatusValues}"
                          SelectedItem="{Binding Card.Status}"
                          Style="{StaticResource StatusComboBoxStyle}"
                          ToolTip="card status"
                          HorizontalAlignment="Center"/>

                <DatePicker Grid.Column="1"
                            SelectedDate="{Binding Card.DueDate}"
                            Style="{StaticResource ThemedDatePickerStyle}"
                            ToolTip="due date"
                            HorizontalAlignment="Center"/>
            </Grid>

            <!-- Info Dates (created at / updaterd at) -->
            <Grid Grid.Row="3" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{Binding Theme.ColumnBackground}"
                        BorderBrush="{Binding Theme.ColumnBorder}"
                        BorderThickness="2"
                        CornerRadius="8"
                        Padding="5"
                        Margin="10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="created at" 
                                   Foreground="{Binding Theme.TextColor}"
                                   FontSize="11"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding Card.CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                   Foreground="{Binding Theme.TextColor}"
                                   FontSize="13"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{Binding Theme.ColumnBackground}"
                        BorderBrush="{Binding Theme.ColumnBorder}"
                        BorderThickness="2"
                        CornerRadius="8"
                        Padding="5"
                        Margin="10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="updated at"
                                   Foreground="{Binding Theme.TextColor}"
                                   FontSize="11"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding Card.UpdatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                   Foreground="{Binding Theme.TextColor}"
                                   FontSize="13"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>